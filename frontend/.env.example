# ============================================================
# AI FASHION STUDIO — FRONTEND ENVIRONMENT VARIABLES
# Copy to .env.local — NEVER commit .env.local
# ============================================================

# Backend API URL — leave empty in dev (Vite proxy handles it)
# Set to your deployed backend URL in production:
# VITE_API_BASE_URL=https://your-backend.azurewebsites.net
VITE_API_BASE_URL=https://airepoimagetest.vercel.app/

# Stripe publishable key (safe to expose — this is the PUBLIC key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App environment
VITE_APP_ENV=development

# Optional: override the proxy target in dev
# VITE_API_PROXY=http://localhost:3001
