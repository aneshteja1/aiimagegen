# ============================================================
# AI FASHION STUDIO — BACKEND ENVIRONMENT VARIABLES
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ── PostgreSQL ───────────────────────────────────────────────
# For local:   postgresql://user:pass@localhost:5432/aifashion
# For Azure:   use Azure Database for PostgreSQL connection string
# For Supabase: use their connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/aifashion
DATABASE_SSL=false       # set true in production

# ── JWT Secrets (generate with: openssl rand -base64 64) ────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Google AI (Gemini) ───────────────────────────────────────
AI_KEY=your_google_ai_key_from_aistudio

# ── Google Vertex AI ─────────────────────────────────────────
VERTEX_AI_PROJECT_ID=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1
# Local: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Production: base64-encoded service account JSON
VERTEX_AI_CREDENTIALS_BASE64=

# ── Email (SMTP) ─────────────────────────────────────────────
# For dev: use Mailtrap (https://mailtrap.io) or Ethereal
# For prod: use SendGrid / AWS SES / Postmark
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM="AI Fashion Studio <noreply@aifashionstudio.com>"

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Frontend URL (for email links) ───────────────────────────
FRONTEND_URL=http://localhost:5173

# ── External FaceSwap Service ────────────────────────────────
FACESWAP_UPSTREAM_URL=https://model-osprey-487816-m4.uc.r.appspot.com/api/v1/faceswap

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AI_MAX=20
